# ─────────────────────────────────────────────────────────────────────────────
# TradingAlerts — Environment Variables
# Copy this file to .env and fill in the real values before launch.
# NEVER commit .env to git. Add it to .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth (from Google Cloud Console → Credentials → OAuth 2.0 Client) ─
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── Stripe (from stripe.com/dashboard → Developers → API Keys) ────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PRICE_ID=price_your-stripe-price-id-here
# From Stripe Dashboard → Webhooks → your endpoint → Signing secret:
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── Flask Session Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
FLASK_SECRET_KEY=change_this_to_a_64_char_random_hex_string

# ── Alpaca (already in your .env) ─────────────────────────────────────────────
APCA_API_KEY_ID=your_alpaca_key
APCA_API_SECRET_KEY=your_alpaca_secret
APCA_API_BASE_URL=https://paper-api.alpaca.markets
